# Managed by Ansible — kernel security hardening

# Network stack
net.ipv4.conf.all.accept_redirects = 0
net.ipv4.conf.default.accept_redirects = 0
net.ipv4.conf.all.send_redirects = 0
net.ipv4.conf.all.accept_source_route = 0
net.ipv4.conf.all.log_martians = 1
net.ipv4.icmp_echo_ignore_broadcasts = 1
net.ipv4.conf.all.rp_filter = 1
net.ipv4.tcp_syncookies = 1

# Restrict kernel info
kernel.kptr_restrict = 2
kernel.dmesg_restrict = 1

# Restrict unprivileged access
kernel.unprivileged_bpf_disabled = 1

# Restrict ptrace — prevents credential extraction from other process memory
# Level 2: only root may ptrace (safe for diagnostic tools)
kernel.yama.ptrace_scope = 2

# Symlink/hardlink protection — prevents certain privilege escalation attacks
fs.protected_symlinks = 1
fs.protected_hardlinks = 1

# Restrict kernel performance counters to privileged users
kernel.perf_event_paranoid = 3

# ARP spoofing protection — only respond to ARP on correct interface
net.ipv4.conf.all.arp_ignore = 1
net.ipv4.conf.all.arp_announce = 2

# Reduce swap aggressiveness — keep data in RAM for ZFS ARC efficiency
vm.swappiness = 10
