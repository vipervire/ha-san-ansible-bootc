#!/bin/bash
# Managed by Ansible — ZFS scrub wrapper script
# This script ensures scrubs only run on the node that owns the pool

set -euo pipefail

POOL_NAME="${1:-{{ zfs_pool_name }}}"
LOG_PREFIX="[zfs-scrub]"

log() {
    echo "${LOG_PREFIX} $*" >&2
}

# Check if pool exists and is imported on this node
if ! zpool list -H -o name "${POOL_NAME}" &>/dev/null; then
    log "Pool '${POOL_NAME}' is not imported on this node (likely standby). Skipping scrub."
    exit 0
fi

log "Pool '${POOL_NAME}' is imported. Proceeding with pre-scrub checks..."

# Capture pool status once and reuse for all checks below
POOL_STATUS=$(zpool status "${POOL_NAME}" 2>/dev/null || true)

# Check if pool is in a healthy state
if zpool status -x "${POOL_NAME}" | grep -qv "pool '${POOL_NAME}' is healthy"; then
    log "WARNING: Pool '${POOL_NAME}' is not healthy. Checking status..."

    # Check for specific conditions that should block scrub
    if echo "${POOL_STATUS}" | grep -q "resilver in progress"; then
        log "ERROR: Resilver in progress. Skipping scrub to avoid performance impact."
        exit 0
    fi

    if echo "${POOL_STATUS}" | grep -q "scrub in progress"; then
        log "INFO: Scrub already in progress. Nothing to do."
        exit 0
    fi

{% if zfs_scrub_skip_on_degraded | default(true) %}
    if echo "${POOL_STATUS}" | grep -qE "(DEGRADED|FAULTED|UNAVAIL)"; then
        log "ERROR: Pool is degraded/faulted. Skipping scrub. Manual intervention required."
        exit 1
    fi
{% endif %}

    log "WARNING: Pool has issues but proceeding with scrub per configuration."
fi

# Check if a scrub was recently completed
LAST_SCRUB=$(echo "${POOL_STATUS}" | grep "scan:" | grep -oE "[0-9]{4}-[0-9]{2}-[0-9]{2}" | tail -1 || echo "never")
if [ "${LAST_SCRUB}" != "never" ]; then
    LAST_SCRUB_EPOCH=$(date -d "${LAST_SCRUB}" +%s)
    NOW_EPOCH=$(date +%s)
    DAYS_SINCE_SCRUB=$(( (NOW_EPOCH - LAST_SCRUB_EPOCH) / 86400 ))

    if [ ${DAYS_SINCE_SCRUB} -lt {{ zfs_scrub_min_interval_days | default(25) }} ]; then
        log "Last scrub was ${DAYS_SINCE_SCRUB} days ago (${LAST_SCRUB}). Skipping (minimum interval: {{ zfs_scrub_min_interval_days | default(25) }} days)."
        exit 0
    fi

    log "Last scrub was ${DAYS_SINCE_SCRUB} days ago (${LAST_SCRUB}). Starting new scrub..."
else
    log "No previous scrub found. Starting scrub..."
fi

# Start the scrub
log "Starting scrub on pool '${POOL_NAME}'..."
if zpool scrub "${POOL_NAME}"; then
    log "Scrub successfully initiated on '${POOL_NAME}'."

    # Optionally log current status
    zpool status "${POOL_NAME}" | grep -A 2 "scan:"

    exit 0
else
    log "ERROR: Failed to start scrub on '${POOL_NAME}'."
    exit 1
fi
