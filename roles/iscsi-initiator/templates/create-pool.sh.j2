#!/bin/bash
# Managed by Ansible — ZFS pool creation helper for {{ inventory_hostname }}
#
# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  MANUAL STEP: Run this script AFTER both nodes have iSCSI sessions    ║
# ║  established and you have verified the device paths below are correct. ║
# ╚══════════════════════════════════════════════════════════════════════════╝
#
# Usage:
#   1. Verify iSCSI sessions:  iscsiadm -m session
#   2. List iSCSI device paths: ls -la /dev/disk/by-path/ | grep iscsi
#   3. Update the REMOTE_DISKS array below with actual paths
#   4. Run:  bash /root/create-pool.sh
#
set -euo pipefail

POOL="{{ zfs_pool_name }}"

# ─── Local disks (by partition label) ───────────────────────────────────────
LOCAL_DISKS=(
{% for disk in local_data_disks %}
  "/dev/disk/by-partlabel/{{ disk.label }}"
{% endfor %}
)

{% if slog_disk is defined %}
# ─── SLOG device (NVMe write log accelerator) ────────────────────────────────
LOCAL_SLOG="{{ slog_disk.device }}"
REMOTE_SLOG="FIXME:replace-with-iscsi-by-path-for-slog"
{% endif %}

{% if special_disk is defined %}
# ─── Special vdev (metadata/small-block accelerator) ─────────────────────────
LOCAL_SPECIAL="{{ special_disk.device }}"
REMOTE_SPECIAL="FIXME:replace-with-iscsi-by-path-for-special"
{% endif %}

# ─── Auto-discover remote iSCSI disk paths by LUN number ─────────────────────
# The peer target assigns LUN numbers sequentially matching local_data_disks order:
#   LUN 0 → local_data_disks[0], LUN 1 → local_data_disks[1], …
# We discover each LUN individually by number to guarantee correct pairing.
# A sort-based approach is NOT used because LUN count, session count, or
# /dev/by-path enumeration order could mismatch, silently pairing wrong disks.
echo "=== Attempting auto-discovery of iSCSI device paths by LUN number ==="
REMOTE_DISKS=()
discovery_ok=true

if ! iscsiadm -m session &>/dev/null; then
  echo "WARNING: No active iSCSI sessions. Cannot auto-discover remote paths."
  discovery_ok=false
fi

if [[ "${discovery_ok}" == "true" ]]; then
  for i in "${!LOCAL_DISKS[@]}"; do
    lun_entry=$(ls /dev/disk/by-path/ 2>/dev/null \
      | grep "ip-{{ iscsi_peer_ip }}:3260" \
      | grep -- "-lun-${i}$" \
      | head -1)
    if [[ -n "${lun_entry}" ]]; then
      echo "  LUN ${i}: /dev/disk/by-path/${lun_entry}"
      REMOTE_DISKS+=("/dev/disk/by-path/${lun_entry}")
    else
      echo "  LUN ${i}: NOT FOUND — falling back to FIXME placeholder"
      REMOTE_DISKS+=("FIXME:lun-${i}-not-found-check-iscsi-session")
      discovery_ok=false
    fi
  done
fi

if [[ "${discovery_ok}" == "false" ]]; then
  echo ""
  echo "Auto-discovery incomplete. Fix any FIXME entries above before continuing."
  echo "Hint: iscsiadm -m session && ls /dev/disk/by-path/ | grep iscsi"
  echo ""
fi

# ─── Verify disks exist ────────────────────────────────────────────────────
echo "=== Verifying disk paths ==="
errors=0
for i in "${!LOCAL_DISKS[@]}"; do
  if [[ ! -e "${LOCAL_DISKS[$i]}" ]]; then
    echo "ERROR: Local disk not found: ${LOCAL_DISKS[$i]}"
    ((errors++))
  fi
  if [[ "${REMOTE_DISKS[$i]}" == FIXME* ]]; then
    echo "ERROR: Remote disk $i not configured — edit this script first"
    ((errors++))
  elif [[ ! -e "${REMOTE_DISKS[$i]}" ]]; then
    echo "ERROR: Remote disk not found: ${REMOTE_DISKS[$i]}"
    ((errors++))
  fi
done

if [[ $errors -gt 0 ]]; then
  echo ""
  echo "Found $errors errors. Fix disk paths and re-run."
  echo "Hint: ls -la /dev/disk/by-path/ | grep iscsi"
  exit 1
fi

# ─── Label local disks with GPT partition labels ──────────────────────────
echo "=== Labeling local disks ==="
{% for disk in local_data_disks %}
echo "Labeling {{ disk.device }} as {{ disk.label }}"
sgdisk -Z {{ disk.device }} 2>/dev/null || true
sgdisk -n1:0:0 -t1:bf01 -c1:"{{ disk.label }}" {{ disk.device }}
{% endfor %}

# Wait for udev to settle
udevadm settle

# ─── Build zpool create command ────────────────────────────────────────────
echo "=== Creating ZFS pool: $POOL ==="

MIRROR_ARGS=""
for i in "${!LOCAL_DISKS[@]}"; do
  MIRROR_ARGS+="  mirror ${LOCAL_DISKS[$i]} ${REMOTE_DISKS[$i]}"
{% raw %}
  if [[ $i -lt $((${#LOCAL_DISKS[@]} - 1)) ]]; then
{% endraw %}
    MIRROR_ARGS+=" \\"$'\n'
  fi
done

# ─── Optional vdevs (SLOG + special) ─────────────────────────────────────────
OPTIONAL_VDEVS=""
{% if slog_disk is defined %}
if [[ "${LOCAL_SLOG}" != "" && "${REMOTE_SLOG}" != FIXME* ]]; then
  OPTIONAL_VDEVS+=" log mirror ${LOCAL_SLOG} ${REMOTE_SLOG}"
elif [[ "${LOCAL_SLOG}" != "" ]]; then
  echo "WARNING: Remote SLOG path not set. SLOG will NOT be added."
  echo "         Edit REMOTE_SLOG above and re-run to add mirrored SLOG."
fi
{% endif %}
{% if special_disk is defined %}
if [[ "${LOCAL_SPECIAL}" != "" && "${REMOTE_SPECIAL}" != FIXME* ]]; then
  OPTIONAL_VDEVS+=" special mirror ${LOCAL_SPECIAL} ${REMOTE_SPECIAL}"
fi
{% endif %}

set -x
# shellcheck disable=SC2086
zpool create \
  -o multihost=on \
  -o ashift={{ zfs_pool_ashift }} \
{% for key, value in zfs_pool_options.items() %}
  -o {{ key }}={{ value }} \
{% endfor %}
{% for key, value in zfs_dataset_options.items() %}
  -O {{ key }}={{ value }} \
{% endfor %}
  "$POOL" \
$MIRROR_ARGS \
$OPTIONAL_VDEVS
set +x

echo ""
echo "=== Pool created successfully ==="
zpool status "$POOL"
echo ""
echo "=== Creating datasets ==="
{% for ds in zfs_datasets %}
zfs create \
{% for key, value in ds.properties.items() %}
  -o {{ key }}={{ value }} \
{% endfor %}
  {{ ds.name }}
echo "Created: {{ ds.name }}"
{% endfor %}

echo ""
echo "=== Pool and datasets ready ==="
zfs list -r "$POOL"
echo ""
echo "Next steps:"
echo "  1. Verify:  zpool status $POOL"
echo "  2. Export:   zpool export $POOL"
echo "  3. Test import on Node B:  zpool import -f -o cachefile=none $POOL"
echo "  4. Then configure Pacemaker resources (run the cluster playbook)"
