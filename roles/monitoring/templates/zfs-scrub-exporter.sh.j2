#!/bin/bash
# Managed by Ansible — ZFS scrub metrics exporter for Prometheus
# Exports ZFS scrub status as Prometheus textfile collector metrics

set -euo pipefail

POOL_NAME="{{ zfs_pool_name }}"
TEXTFILE_DIR="/var/lib/prometheus/node-exporter"
TEXTFILE="${TEXTFILE_DIR}/zfs_scrub.prom"
TEXTFILE_TMP="${TEXTFILE}.$$"

# Ensure textfile directory exists
mkdir -p "${TEXTFILE_DIR}"
trap 'rm -f "${TEXTFILE_TMP}"' EXIT

# Start building metrics
{
    echo "# HELP zfs_scrub_last_run_timestamp_seconds Unix timestamp of last scrub completion"
    echo "# TYPE zfs_scrub_last_run_timestamp_seconds gauge"

    echo "# HELP zfs_scrub_last_run_errors_total Total errors found in last scrub"
    echo "# TYPE zfs_scrub_last_run_errors_total gauge"

    echo "# HELP zfs_scrub_in_progress Whether a scrub is currently in progress (1=yes, 0=no)"
    echo "# TYPE zfs_scrub_in_progress gauge"

    echo "# HELP zfs_scrub_pool_imported Whether the pool is imported on this node (1=yes, 0=no)"
    echo "# TYPE zfs_scrub_pool_imported gauge"

    echo "# HELP zfs_scrub_pool_health Pool health status (0=ONLINE, 1=DEGRADED, 2=FAULTED, 3=UNAVAIL, 4=UNKNOWN)"
    echo "# TYPE zfs_scrub_pool_health gauge"

    echo "# HELP zfs_scrub_exporter_success Whether the metrics collection succeeded (1=yes, 0=no)"
    echo "# TYPE zfs_scrub_exporter_success gauge"

    echo "# HELP zfs_pool_size_bytes Total pool size in bytes"
    echo "# TYPE zfs_pool_size_bytes gauge"

    echo "# HELP zfs_pool_allocated_bytes Pool space currently in use"
    echo "# TYPE zfs_pool_allocated_bytes gauge"

    echo "# HELP zfs_pool_free_bytes Pool space available"
    echo "# TYPE zfs_pool_free_bytes gauge"

    echo "# HELP zfs_pool_fragmentation_percent Pool fragmentation percentage"
    echo "# TYPE zfs_pool_fragmentation_percent gauge"

    echo "# HELP zfs_vdev_read_errors Read errors per vdev"
    echo "# TYPE zfs_vdev_read_errors counter"

    echo "# HELP zfs_vdev_write_errors Write errors per vdev"
    echo "# TYPE zfs_vdev_write_errors counter"

    echo "# HELP zfs_vdev_cksum_errors Checksum errors per vdev"
    echo "# TYPE zfs_vdev_cksum_errors counter"

    echo "# HELP zfs_resilver_in_progress Whether a resilver is in progress (1=yes, 0=no)"
    echo "# TYPE zfs_resilver_in_progress gauge"

    echo "# HELP zfs_resilver_percent_complete Resilver completion percentage"
    echo "# TYPE zfs_resilver_percent_complete gauge"

    echo "# HELP zfs_dataset_last_snapshot_seconds Unix timestamp of most recent snapshot per dataset"
    echo "# TYPE zfs_dataset_last_snapshot_seconds gauge"

    # Check if pool is imported
    if ! zpool list -H -o name "${POOL_NAME}" &>/dev/null; then
        # Pool not imported - this node is standby
        echo "zfs_scrub_pool_imported{pool=\"${POOL_NAME}\"} 0"
        echo "zfs_scrub_last_run_timestamp_seconds{pool=\"${POOL_NAME}\"} 0"
        echo "zfs_scrub_last_run_errors_total{pool=\"${POOL_NAME}\"} 0"
        echo "zfs_scrub_in_progress{pool=\"${POOL_NAME}\"} 0"
        echo "zfs_scrub_pool_health{pool=\"${POOL_NAME}\"} 4"
        echo "zfs_scrub_exporter_success 1"
    else
        # Pool is imported - this node is active
        echo "zfs_scrub_pool_imported{pool=\"${POOL_NAME}\"} 1"

        # Get pool status
        POOL_STATUS=$(zpool status "${POOL_NAME}" 2>/dev/null || echo "")

        if [ -z "${POOL_STATUS}" ]; then
            echo "zfs_scrub_exporter_success 0"
            exit 0
        fi

        # Parse pool health
        POOL_HEALTH=$(echo "${POOL_STATUS}" | grep "state:" | awk '{print $2}')
        case "${POOL_HEALTH}" in
            ONLINE)  HEALTH_CODE=0 ;;
            DEGRADED) HEALTH_CODE=1 ;;
            FAULTED) HEALTH_CODE=2 ;;
            UNAVAIL) HEALTH_CODE=3 ;;
            *) HEALTH_CODE=4 ;;
        esac
        echo "zfs_scrub_pool_health{pool=\"${POOL_NAME}\",state=\"${POOL_HEALTH}\"} ${HEALTH_CODE}"

        # Parse scrub status
        SCAN_LINE=$(echo "${POOL_STATUS}" | grep "scan:" || echo "")

        # Check if scrub is in progress
        if echo "${SCAN_LINE}" | grep -q "scrub in progress"; then
            echo "zfs_scrub_in_progress{pool=\"${POOL_NAME}\"} 1"
        else
            echo "zfs_scrub_in_progress{pool=\"${POOL_NAME}\"} 0"
        fi

        # Extract last scrub date and convert to timestamp
        # Format: "scan: scrub repaired 0B in 00:45:23 with 0 errors on 2025-01-15 02:00:23"
        SCRUB_DATE=$(echo "${SCAN_LINE}" | grep -oE "[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}" | tail -1 || echo "")

        if [ -n "${SCRUB_DATE}" ]; then
            SCRUB_TIMESTAMP=$(date -d "${SCRUB_DATE}" +%s 2>/dev/null || echo "0")
            echo "zfs_scrub_last_run_timestamp_seconds{pool=\"${POOL_NAME}\"} ${SCRUB_TIMESTAMP}"
        else
            # No scrub has ever run
            echo "zfs_scrub_last_run_timestamp_seconds{pool=\"${POOL_NAME}\"} 0"
        fi

        # Extract error count
        if echo "${SCAN_LINE}" | grep -q "with [0-9]* errors"; then
            ERROR_COUNT=$(echo "${SCAN_LINE}" | grep -oE "with [0-9]* errors" | grep -oE "[0-9]+" || echo "0")
            echo "zfs_scrub_last_run_errors_total{pool=\"${POOL_NAME}\"} ${ERROR_COUNT}"
        else
            echo "zfs_scrub_last_run_errors_total{pool=\"${POOL_NAME}\"} 0"
        fi

        # ─── Pool capacity ─────────────────────────────────────────────
        POOL_DATA=$(zpool list -H -p -o size,alloc,free,frag "${POOL_NAME}" 2>/dev/null || echo "")
        if [ -n "${POOL_DATA}" ]; then
            POOL_SIZE=$(echo "${POOL_DATA}" | awk '{print $1}')
            POOL_ALLOC=$(echo "${POOL_DATA}" | awk '{print $2}')
            POOL_FREE=$(echo "${POOL_DATA}" | awk '{print $3}')
            POOL_FRAG=$(echo "${POOL_DATA}" | awk '{print $4}' | tr -d '%')
            echo "zfs_pool_size_bytes{pool=\"${POOL_NAME}\"} ${POOL_SIZE}"
            echo "zfs_pool_allocated_bytes{pool=\"${POOL_NAME}\"} ${POOL_ALLOC}"
            echo "zfs_pool_free_bytes{pool=\"${POOL_NAME}\"} ${POOL_FREE}"
            echo "zfs_pool_fragmentation_percent{pool=\"${POOL_NAME}\"} ${POOL_FRAG}"
        fi

        # ─── Per-vdev error counts ──────────────────────────────────────
        while IFS= read -r vdev_line; do
            if echo "${vdev_line}" | grep -qE "^\s+(/dev/disk/by-id/|/dev/disk/by-path/|/dev/sd|/dev/nvme)[^ ]+\s+"; then
                VDEV=$(echo "${vdev_line}" | awk '{print $1}' | xargs basename)
                READ_ERR=$(echo "${vdev_line}" | awk '{print $3}')
                WRITE_ERR=$(echo "${vdev_line}" | awk '{print $4}')
                CKSUM_ERR=$(echo "${vdev_line}" | awk '{print $5}')
                [[ "${READ_ERR}"  =~ ^[0-9]+$ ]] || READ_ERR=0
                [[ "${WRITE_ERR}" =~ ^[0-9]+$ ]] || WRITE_ERR=0
                [[ "${CKSUM_ERR}" =~ ^[0-9]+$ ]] || CKSUM_ERR=0
                echo "zfs_vdev_read_errors{pool=\"${POOL_NAME}\",vdev=\"${VDEV}\"} ${READ_ERR}"
                echo "zfs_vdev_write_errors{pool=\"${POOL_NAME}\",vdev=\"${VDEV}\"} ${WRITE_ERR}"
                echo "zfs_vdev_cksum_errors{pool=\"${POOL_NAME}\",vdev=\"${VDEV}\"} ${CKSUM_ERR}"
            fi
        done <<< "${POOL_STATUS}"

        # ─── Resilver progress ──────────────────────────────────────────
        if echo "${POOL_STATUS}" | grep -q "resilver in progress"; then
            echo "zfs_resilver_in_progress{pool=\"${POOL_NAME}\"} 1"
            RESILVER_PCT=$(echo "${POOL_STATUS}" | grep -oE "[0-9]+\.[0-9]+%" | head -1 | tr -d '%' || echo "0")
            echo "zfs_resilver_percent_complete{pool=\"${POOL_NAME}\"} ${RESILVER_PCT:-0}"
        else
            echo "zfs_resilver_in_progress{pool=\"${POOL_NAME}\"} 0"
            echo "zfs_resilver_percent_complete{pool=\"${POOL_NAME}\"} 0"
        fi

        # ─── Snapshot age per dataset ───────────────────────────────────
{% for ds in sanoid_datasets | default([]) %}
        LAST_SNAP=$(zfs list -H -o creation -t snapshot -s creation "{{ ds.name }}" 2>/dev/null | tail -1)
        if [ -n "${LAST_SNAP}" ]; then
            SNAP_TS=$(date -d "${LAST_SNAP}" +%s 2>/dev/null || echo "0")
            echo "zfs_dataset_last_snapshot_seconds{dataset=\"{{ ds.name }}\"} ${SNAP_TS}"
        fi
{% endfor %}

        echo "zfs_scrub_exporter_success 1"
    fi
} > "${TEXTFILE_TMP}"

# Atomically replace the metrics file
mv "${TEXTFILE_TMP}" "${TEXTFILE}"

# Set permissions so node_exporter can read it
chmod 644 "${TEXTFILE}"
