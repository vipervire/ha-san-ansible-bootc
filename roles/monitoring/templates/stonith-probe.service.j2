# Managed by Ansible — STONITH agent reachability probe service
[Unit]
Description=STONITH agent reachability probe for Prometheus

[Service]
Type=oneshot
ExecStart=/usr/local/bin/stonith-probe
StandardOutput=journal
StandardError=journal
SyslogIdentifier=stonith-probe

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/prometheus/node-exporter
